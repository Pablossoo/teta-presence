{
  "manifest_version": 3,
  "name": "Teta Presence Bot",
  "version": "1.0.0",
  "description": "Automatycznie klika potwierdzenie obecności w Teta.",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://lm.me5.pub.unit4bs.pl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
